{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Model Training (uv run)",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "python",
                "-m",
                "src.cli.model_training"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "LME_CONFIG_FILE": "${workspaceFolder}/config.toml"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Run the ClearML model-training DAG through uv using config.toml defaults.",
            "problemMatcher": []
        }
    ]
}
